msgid "Enter the 6-digit code from your authenticator app or a backup code."
msgstr "Cuir isteach an cód 6 dhigit ó d’aip fíordheimhnitheora nó cód cúltaca."

#: ../../../app/views/users/sessions/otp.html.erb:8
