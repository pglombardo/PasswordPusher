#: ../../../app/views/users/first_runs/new.html.erb:153
msgid ""
"Share passwords, notes, URLs, and files with configurable expiration and view "
"limits."
msgstr ""
"Comhroinn pasfhocail, nótaí, URLanna agus comhaid le teorainneacha inchumraith"
"e maidir le dul in éag agus radhairc."

#: ../../../app/views/users/first_runs/new.html.erb:161
