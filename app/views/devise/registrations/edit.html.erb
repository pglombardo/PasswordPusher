<% title(I18n.t('devise.registrations.edit_account')) %>

<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6">

      <h2 class="fw-semibold mb-4"><em class="bi bi-person-gear me-2"></em><%= I18n.t('devise.registrations.edit_account') %></h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-4">
          <h5 class="fw-semibold border-bottom pb-2 mb-3"><em class="bi bi-envelope me-2"></em><%= I18n.t('devise.registrations.update_email') %></h5>
          <div class="form-floating">
            <%= f.email_field :email, class: 'form-control', autofocus: true, autocomplete: "email", placeholder: "name@example.org" %>
            <%= f.label _('Email'), for: :user_email %>
          </div>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="alert alert-info mt-2 small"><em class="bi bi-hourglass-split me-1"></em><%= I18n.t('devise.registrations.currently_waiting') %>: <%= resource.unconfirmed_email %></div>
          <% end %>
        </div>

        <% if I18n.available_locales.length > 1 %>
          <div class="mb-4">
            <h5 class="fw-semibold border-bottom pb-2 mb-3"><em class="bi bi-globe me-2"></em><%= I18n.t('devise.registrations.preferred_language') %></h5>
            <%= f.select :preferred_language, options_for_select(language_options_for_select, resource.preferred_language || I18n.locale), { selected: resource.preferred_language || I18n.locale }, { class: "form-select" } %>
          </div>
        <% end %>

        <div class="mb-4">
          <h5 class="fw-semibold border-bottom pb-2 mb-3"><em class="bi bi-key me-2"></em><%= I18n.t('devise.registrations.change_password') %></h5>
          <p class="text-muted small"><%= I18n.t('devise.registrations.change_password_hint') %></p>
          <div class="form-floating mb-2">
            <%= f.password_field :password, class: 'form-control', autocomplete: "new-password", placeholder: I18n.t('devise.registrations.new_password') %>
            <%= f.label I18n.t('devise.registrations.new_password'), for: :user_password %>
          </div>
          <div class="form-floating">
            <%= f.password_field :password_confirmation, class: 'form-control', autocomplete: "new-password", placeholder: I18n.t('devise.registrations.password') %>
            <%= f.label I18n.t('devise.registrations.new_password_confirmation'), for: :user_password_confirmation %>
          </div>
          <% if @minimum_password_length %>
            <p class="text-muted small mt-2 mb-0">
              <em class="bi bi-info-circle me-1"></em><%= sprintf(I18n.t('devise.registrations.password_minimum'), @minimum_password_length) %>
            </p>
          <% end %>
        </div>

        <div class="mb-4">
          <h5 class="fw-semibold border-bottom pb-2 mb-3"><em class="bi bi-shield-check me-2"></em><%= I18n.t('devise.registrations.verification') %></h5>
          <p class="text-muted small"><%= I18n.t('devise.registrations.verification_text') %></p>
          <div class="form-floating">
            <%= f.password_field :current_password, class: 'form-control', autocomplete: "current-password", placeholder: I18n.t('devise.registrations.password') %>
            <%= f.label _("Current Password"), for: :user_current_password %>
          </div>
        </div>

        <div class="d-grid mb-4">
          <button class="btn btn-primary btn-lg" type="submit"><em class="bi bi-check-lg me-2"></em><%= I18n.t('devise.registrations.update_account') %></button>
        </div>
      <% end %>

      <hr class="my-4">

      <div class="mb-4">
        <h5 class="fw-semibold border-bottom pb-2 mb-3"><em class="bi bi-shield-lock me-2"></em><%= _("Two-factor authentication") %></h5>
        <p class="text-muted small"><%= _("Add a second step to your sign-in using an authenticator app (TOTP).") %></p>
        <% if resource.otp_required_for_login? %>
          <%= button_to _("Disable two-factor authentication"), user_two_factor_path,
            method: :delete,
            class: "btn btn-outline-danger",
            form: { data: { turbo_confirm: _("Are you sure?") } } %>
        <% else %>
          <%= link_to _("Set up two-factor authentication"), backup_codes_user_two_factor_path, class: "btn btn-secondary" %>
        <% end %>
      </div>

      <hr class="my-4">

      <div class="mb-4">
        <h5 class="fw-semibold text-danger mb-3"><em class="bi bi-exclamation-triangle me-2"></em><%= I18n.t('devise.registrations.edit.cancel_my_account') %></h5>
        <p class="text-muted small"><%= I18n.t('devise.registrations.edit.cancel_my_account_description') %></p>
        <%= button_to registration_path(resource_name),
                      data: { turbo_confirm: I18n.t('devise.registrations.edit.are_you_sure') },
                      method: :delete,
                      class: "btn btn-outline-danger" do %>
          <em class="bi bi-trash me-1"></em><%= I18n.t('devise.registrations.edit.cancel_my_account') %>
        <% end %>
      </div>

    </div>
  </div>
</main>
