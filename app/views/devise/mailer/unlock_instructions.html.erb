<h1><%= _('Unlock Your Account') %></h1>

<p>
<%= _('Your account has been locked due to an excessive number of unsuccessful sign in attempts.') %>
</p>

<p>
<%= link_to _('Click this link'), unlock_url(@resource, unlock_token: @token) %>
<%= _('to unlock your account or by copying and pasting the following URL into your browser:') %>
</p>

<pre class="chroma">
<%= unlock_url(@resource, unlock_token: @token) %>
</pre>
</p>
<%= render 'shared/email_footer' %>
