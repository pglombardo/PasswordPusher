<% notify_by_email = audit_log.notify_by_email %>
<% status_class = case notify_by_email.status
  when "completed" then "list-group-item-success"
  when "processing", "pending" then "list-group-item-info"
  when "partially_failed" then "list-group-item-warning"
  when "fully_failed" then "list-group-item-danger"
  else "list-group-item-info"
end %>

<% status_icon = case notify_by_email.status
  when "completed" then "bi-envelope-check"
  when "processing" then "bi-hourglass-split"
  when "pending" then "bi-envelope"
  when "partially_failed" then "bi-envelope-exclamation"
  when "fully_failed" then "bi-envelope-x"
  else "bi-envelope"
end %>

<div class="list-group-item list-group-item-action <%= status_class %>">
  <em class="bi <%= status_icon %>"></em>
  <% if notify_by_email.completed? %>
    <%= _('Email notification(s) sent on %{date}') % {
        date: I18n.l(audit_log.created_at.in_time_zone(Settings.timezone))
    } %>
  <% elsif notify_by_email.pending? %>
    <%= _('Email notification(s) pending') %>
  <% elsif notify_by_email.processing? %>
    <%= _('Email notification(s) being sent...') %>
  <% elsif notify_by_email.partially_failed? %>
    <%= _('Some email notification(s) failed on %{date}') % {
        date: I18n.l(audit_log.created_at.in_time_zone(Settings.timezone))
    } %>
  <% elsif notify_by_email.fully_failed? %>
    <%= _('Email notification(s) failed on %{date}') % {
        date: I18n.l(audit_log.created_at.in_time_zone(Settings.timezone))
    } %>
  <% end %>
  <br>
  <strong><%= _('To:') %></strong> <code><%= notify_by_email.recipients %></code>
  <% if notify_by_email.partially_failed? %>
    <br>
    <strong><%= _('Sent:') %></strong> <code><%= notify_by_email.successful_sends %></code>
  <% end %>
</div>
