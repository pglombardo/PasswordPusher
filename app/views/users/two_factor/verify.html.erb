<% title(_("Verify authenticator")) %>

<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-xl-6 text-center">
      <h2 class="fw-semibold mb-3"><%= _("Scan this QR code") %></h2>
      <p class="text-muted small mb-3"><%= _("Add this account to your authenticator app, then enter the 6-digit code to confirm.") %></p>
      <div class="d-inline-block p-3 bg-white rounded shadow-sm mb-4">
        <%= qr_code(current_user.totp_provisioning_uri) %>
      </div>
      <p class="small text-muted mb-4"><%= _("If you cannot scan the code, enter this secret manually:") %></p>
      <p class="font-monospace user-select-all mb-4"><%= current_user.totp_manual_entry_secret %></p>

      <%= form_with url: user_two_factor_path, method: :post, data: { turbo: false } do %>
        <div class="form-floating text-start">
          <%= text_field_tag :code, nil, class: "form-control", autocomplete: "one-time-code", inputmode: "numeric", placeholder: _("Code"), autofocus: true, required: true %>
          <%= label_tag :code, _("Verification code"), for: "code" %>
        </div>
        <div class="d-grid mt-3">
          <%= submit_tag _("Enable two-factor authentication"), class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</main>
