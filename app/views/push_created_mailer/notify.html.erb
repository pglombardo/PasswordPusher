<h1 style="font-weight:400;line-height: 1.25; text-align: center;">
  <%= _('You have been sent a push') %>
</h1>

<p>
  <%= _('Please find the secret link below to access the sensitive information.') %>
</p>

<p><%= _('Secret link:') %> <a href="<%= @secret_url %>"><%= @secret_url %></a></p>

<h4 style="font-weight: bold; margin-top: 40px;"><%= _('Important Notes:') %></h4>
<ul style="padding: 0px; list-style-position: inside">
  <li><%= _('This link is valid for %{remaining}, or until %{views} views, whichever occurs first.') % { remaining: format_days_remaining(@push), views: @push.expire_after_views } %></li>
  <li><%= _('For added security, you may be prompted to enter a passphrase (provided separately) to access the content.') %></li>
  <li><%= _('Upon expiration, this secret link and all content are permanently deleted.') %></li>
</ul>
