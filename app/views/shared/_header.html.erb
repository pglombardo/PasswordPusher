<div class="container">
  <header class="d-flex flex-wrap justify-content-center py-3 mb-4 border-bottom">
    <%= link_to root_path, class: 'd-flex align-items-center mb-3 mb-md-0 me-md-auto text-body-emphasis text-decoration-none', hreflang: locale.to_s do %>
      <div class="me-3">
        <picture>
          <% if Settings.brand.nil? || Settings.brand.light_logo.nil? %>
            <source srcset="<%= asset_path('logo-transparent-sm-bare.png') %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
            <source srcset="<%= asset_path('logo-transparent-sm-dark-bare.png') %>" media="(prefers-color-scheme: dark)">
            <img src="<%= asset_path('logo-transparent-sm-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" height="50" class="d-block">
          <% else %>
            <source srcset="<%= Settings.brand.light_logo %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
            <source srcset="<%= Settings.brand.dark_logo %>" media="(prefers-color-scheme: dark)">
            <img src="<%= Settings.brand.light_logo %>" alt="<%= _('Password Pusher Logo') %>" height="50" class="d-block">
          <% end %>
        </picture>
      </div>
      <div class="d-none d-sm-block">
        <span class="fs-4 fw-semibold d-block lh-sm"><%= Settings.brand.title %></span>
        <span class="small text-muted"><%= Settings.brand.tagline %></span>
      </div>
    <% end %>

    <nav class="d-flex align-items-center gap-2">
      <% if current_user %>
        <%= link_to pushes_path, class: "btn btn-primary d-flex align-items-center gap-2" do %>
          <em class="bi bi-grid-3x3-gap-fill"></em>
          <span class="d-none d-sm-inline"><%= _('Dashboard') %></span>
        <% end %>

        <div class="dropdown">
          <button class="btn btn-outline-secondary dropdown-toggle d-flex align-items-center gap-2" type="button" id="accountDropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
            <em class="bi bi-person-circle"></em>
            <span class="d-none d-md-inline"><%= _('Account') %></span>
          </button>
          <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="accountDropdownMenuLink">
            <% if current_user.admin? %>
              <li>
                <%= link_to admin_root_path, class: "dropdown-item d-flex align-items-center gap-2 py-2" do %>
                  <em class="bi bi-shield-check text-primary"></em>
                  <%= _('Administration Center') %>
                <% end %>
              </li>
              <li><hr class="dropdown-divider"></li>
            <% end %>
            <li>
              <%= link_to edit_user_registration_path, class: "dropdown-item d-flex align-items-center gap-2 py-2" do %>
                <em class="bi bi-pencil-square text-secondary"></em>
                <%= _('Edit Login Details') %>
              <% end %>
            </li>
            <li>
              <%= link_to token_user_registration_path, class: "dropdown-item d-flex align-items-center gap-2 py-2" do %>
                <em class="bi bi-key text-secondary"></em>
                <%= _('API Token') %>
              <% end %>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <%= button_to destroy_user_session_path, method: :delete, class: "dropdown-item d-flex align-items-center gap-2 py-2 text-danger", form_class: "d-block" do %>
                <em class="bi bi-box-arrow-right"></em>
                <%= _('Log Out') %>
              <% end %>
            </li>
          </ul>
        </div>
      <% else %>
        <% unless Settings.disable_logins %>
          <%= link_to _('Log In'), new_user_session_path, class: "btn btn-outline-secondary" %>
        <% end %>
        <% unless Settings.disable_signups %>
          <%= link_to _('Sign Up'), new_user_registration_path, class: "btn btn-primary" %>
        <% end %>
      <% end %>
    </nav>
  </header>
</div>
