<div class="bg-body-tertiary border rounded-3 p-3 mb-4">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
    <div class="d-flex align-items-center gap-2">
      <em class="bi bi-grid-3x3-gap-fill fs-4 text-primary"></em>
      <h1 class="h4 mb-0 fw-semibold"><%= _('Dashboard') %></h1>
    </div>

    <div class="d-flex flex-wrap align-items-center gap-2">
      <div class="btn-group" role="group" aria-label="<%= _('Filter pushes') %>">
        <%= link_to pushes_path, class: "btn btn-outline-secondary #{'active' if @filter.blank?}" do %>
          <em class="bi bi-collection me-1"></em><%= _('All') %>
        <% end %>
        <%= link_to pushes_path(filter: :active), class: "btn btn-outline-secondary #{'active' if @filter == 'active'}" do %>
          <em class="bi bi-check-circle me-1"></em><%= _('Active') %>
        <% end %>
        <%= link_to pushes_path(filter: :expired), class: "btn btn-outline-secondary #{'active' if @filter == 'expired'}" do %>
          <em class="bi bi-clock-history me-1"></em><%= _('Expired') %>
        <% end %>
      </div>

      <%= link_to new_push_path, class: "btn btn-primary" do %>
        <em class="bi bi-plus-lg me-1"></em><%= _('New Push') %>
      <% end %>
    </div>
  </div>
</div>
