<footer class="footer mt-auto py-3 border-top">
  <div class="container">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
      <div class="d-flex align-items-center gap-2">
        <%= link_to root_path(locale: locale.to_s), class: "text-decoration-none" do %>
          <picture>
            <% if Settings.brand.nil? || Settings.brand.light_logo.nil? %>
              <source srcset="<%= asset_path('logo-transparent-sm-bare.png') %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
              <source srcset="<%= asset_path('logo-transparent-sm-dark-bare.png') %>" media="(prefers-color-scheme: dark)">
              <img src="<%= asset_path('logo-transparent-sm-bare.png') %>" alt="<%= _('Password Pusher Logo') %>" height="28" class="d-block">
            <% else %>
              <source srcset="<%= Settings.brand.light_logo %>" media="(prefers-color-scheme: light) or (prefers-color-scheme: no-preference)">
              <source srcset="<%= Settings.brand.dark_logo %>" media="(prefers-color-scheme: dark)">
              <img src="<%= Settings.brand.light_logo %>" alt="<%= _('Password Pusher Logo') %>" height="28" class="d-block">
            <% end %>
          </picture>
        <% end %>
        <span class="text-muted small">
          &copy; <%= Time.now.year %>
          <%= link_to "Apnotic", "https://apnotic.com", target: "_blank", rel: "noopener noreferrer", class: "text-muted text-decoration-none" %>
          <% if Settings.show_version %>&middot; v<%= Version.current %><% end %>
        </span>
      </div>

      <% if Settings.brand.show_footer_menu %>
        <nav class="d-flex flex-wrap gap-3 small">
          <%= link_to _('About'), page_path('about'), class: 'text-muted text-decoration-none' %>
          <%= link_to _('Docs'), "https://docs.pwpush.com", target: "_blank", rel: "noopener noreferrer", class: 'text-muted text-decoration-none' %>
          <%= link_to _('GitHub'), "https://github.com/pglombardo/PasswordPusher", target: "_blank", rel: "noopener noreferrer", class: 'text-muted text-decoration-none' %>
        </nav>
      <% end %>
    </div>

    <% if Settings.brand.disclaimer %>
      <p class="text-muted small fst-italic text-center mt-3 mb-0"><%= Settings.brand.disclaimer %></p>
    <% end %>
  </div>
</footer>
