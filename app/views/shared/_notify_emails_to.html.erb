<% unless action_name == 'edit' %>
  <% form_builder = local_assigns[:form] || local_assigns[:f] %>
  <div class="row">
    <div class="col">
      <label class="form-label fw-medium mt-3"><%= _('Auto Dispatch: Send This Secret Link To...') %></label>
      <div class="input-group">
        <span class="input-group-text">
          <i class="bi bi-envelope" aria-hidden="true"></i>
        </span>
        <%= form_builder.text_field(:notify_emails_to, { class: "form-control",
                                              placeholder: _('Enter email(s) separated by commas.'),
                                              autocomplete: "off" }) %>
        <% if form_builder && Settings.language_codes %>
          <%= render "shared/push_locale_dropdown",
              form: form_builder,
              current_locale: form_builder.object.notify_emails_to_locale.presence,
              heading: _('Send emails in the following language:'),
              menu_extra_class: "notify-emails-locale-menu",
              button_class: "btn btn-primary dropdown-toggle d-flex align-items-center gap-2 w-100",
              button_style: "border-top-left-radius: 0; border-bottom-left-radius: 0;" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
